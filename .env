# ============================================================
# SafeZone Frontend — Variables de entorno
# Copia este archivo como .env y ajusta los valores
# ============================================================

# URL base del backend Spring Boot
VITE_API_URL=http://localhost:8080/api

# Modo de datos:
#   true  = usa datos locales (mock), la app funciona SIN backend
#   false = llama al backend Spring Boot real
VITE_USE_MOCK=false
